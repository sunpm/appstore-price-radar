# Worker
# Note: for local `wrangler dev`, prefer placing Worker vars in `apps/worker/.dev.vars`.
# This root `.env` is mainly for web (`VITE_API_BASE`) and as drizzle fallback.
# Neon Postgres connection string (required)
DATABASE_URL=
# Resend API key (required if you want email alerts)
RESEND_API_KEY=
# Sender email under a verified Resend domain (required if you want email alerts)
RESEND_FROM_EMAIL=
# Secret for POST /api/jobs/check authentication (recommended in production)
CRON_SECRET=
# Auth session ttl in days (1-90, default 30)
SESSION_TTL_DAYS=30
# Password reset token ttl in minutes (5-120, default 30)
RESET_PASSWORD_TTL_MINUTES=30
# Email login code ttl in minutes (2-60, default 10)
LOGIN_CODE_TTL_MINUTES=10
# Frontend URL (optional, reserved for links/jumps)
APP_BASE_URL=http://localhost:5173
# CORS allow origin for API
CORS_ORIGIN=http://localhost:5173

# Web
# Worker base URL for frontend requests (required)
VITE_API_BASE=http://127.0.0.1:8787
