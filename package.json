{
  "name": "appstore-price-radar",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n worker,web -c cyan,green \"pnpm dev:worker\" \"pnpm dev:web\"",
    "dev:worker": "pnpm --filter @appstore-price-radar/worker dev",
    "dev:web": "pnpm --filter @appstore-price-radar/web dev",
    "build": "pnpm -r build",
    "test": "pnpm --filter @appstore-price-radar/worker test && pnpm --filter @appstore-price-radar/web test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm --filter @appstore-price-radar/web lint",
    "verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm --filter @appstore-price-radar/worker test:smoke",
    "verify:full": "pnpm verify"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
