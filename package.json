{
  "name": "appstore-price-radar",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.9.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n worker,web -c cyan,green \"pnpm dev:worker\" \"pnpm dev:web\"",
    "dev:worker": "pnpm --filter @appstore-price-radar/worker dev",
    "dev:web": "pnpm --filter @appstore-price-radar/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
